{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "includeFiles": "app/**"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/backend/(.*)",
      "destination": "/api/index"
    }
  ]
}
